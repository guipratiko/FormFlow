{
  "name": "formflow",
  "version": "0.1.0",
  "description": "Microserviço FormFlow — criação e gestão de formulários OnlyFlow",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "start": "node scripts/prisma-migrate.mjs && node dist/main.js",
    "start:dev": "rm -f tsconfig.build.tsbuildinfo && nest start --watch",
    "start:prod": "node dist/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "node scripts/prisma-migrate.mjs",
    "prisma:push": "node scripts/prisma-with-db-url.mjs db push",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/serve-static": "^4.0.2",
    "@nestjs/terminus": "^10.2.3",
    "@prisma/client": "^6.19.0",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^6.19.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3"
  }
}
