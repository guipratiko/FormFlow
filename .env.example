PORT=4341
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# URL pública dos formulários (sem barra final)
# Local: http://localhost:4341  |  Produção: https://forms.onlyflow.com.br
PUBLIC_FORM_BASE_URL=http://localhost:4341

# Prisma: DATABASE_URL ou POSTGRES_URI (mesmo padrão dos demais microsserviços OnlyFlow)
POSTGRES_URI=
DATABASE_URL=

# Mesmo JWT_SECRET do Backend OnlyFlow (validação de tokens do painel)
JWT_SECRET=

# Chave interna OnlyFlow (integrações ManyFlow, CRM, webhooks internos)
ONLYFLOW_INTERNAL_KEY=

# Backend OnlyFlow (automações pós-resposta)
ONLYFLOW_BACKEND_URL=http://localhost:4331

# Redis (cache, filas — opcional no scaffold local)
REDIS_URL=redis://localhost:6379
